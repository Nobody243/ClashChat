rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if a user is signed in
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isIntInRange(value, min, max) {
      return (value is int) && value >= min && value <= max;
    }

    // ── USERS COLLECTION ──
    // Public read for authenticated users is allowed, but writes are strictly
    // limited to the owner and validated to prevent client-side tampering of
    // sensitive numeric or quota fields.
    match /users/{userId} {
      allow read: if isAuthenticated();

      allow create: if isOwner(userId)
        // Require that created user email (if present) matches auth token email
        && ( !('email' in request.resource.data) || request.resource.data.email == request.auth.token.email );

      allow update: if isOwner(userId)
        // If quota limits are present, validate ranges
        && ( !('dailyUsageLimit' in request.resource.data) || isIntInRange(request.resource.data.dailyUsageLimit, 1, 10000) )
        && ( !('dailyUsageUsed' in request.resource.data) || (request.resource.data.dailyUsageUsed is int && request.resource.data.dailyUsageUsed >= 0 && request.resource.data.dailyUsageUsed <= (('dailyUsageLimit' in request.resource.data) ? request.resource.data.dailyUsageLimit : 10000)) )
        // Basic type checks for commonly used fields
        && ( !('avatarSeed' in request.resource.data) || request.resource.data.avatarSeed is string )
        && ( !('isGoogleSignIn' in request.resource.data) || request.resource.data.isGoogleSignIn is bool );

      allow delete: if isOwner(userId);
    }

    // ── DEBATES & HISTORY COLLECTION ──
    // Structure: /debates/{userId}/history/{debateId}
    // Only the owner may create/update/delete their debate documents. Basic
    // schema validation is applied to prevent malformed or malicious writes.
    match /debates/{userId} {
      allow read, write: if isOwner(userId);

      match /history/{debateId} {
        allow read: if isOwner(userId);

        allow create: if isOwner(userId)
          && ( !('status' in request.resource.data) || request.resource.data.status in ['active','completed','cancelled'] )
          && ( !('score' in request.resource.data) || isIntInRange(request.resource.data.score, 0, 100) )
          && ( !('createdAt' in request.resource.data) || request.resource.data.createdAt <= request.time );

        allow update: if isOwner(userId)
          && ( !('score' in request.resource.data) || isIntInRange(request.resource.data.score, 0, 100) )
          && ( !('status' in request.resource.data) || request.resource.data.status in ['active','completed','cancelled'] );

        allow delete: if isOwner(userId);
      }
    }

    // Default deny for everything else to ensure strict security
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
